#include <stdio.h>
#include <stdlib.h>

// Node structure
struct Node {
    int data;
    struct Node* next;
};

struct Node* head = NULL;

// Create circular linked list
void create(int x) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = x;

    if (head == NULL) {
        head = newNode;
        newNode->next = head;
    } else {
        struct Node* temp = head;
        while (temp->next != head) {
            temp = temp->next;
        }
        temp->next = newNode;
        newNode->next = head;
    }
}

// Delete last node
void deleteLast() {
    if (head == NULL)
        return;

    struct Node* temp = head;

    // Only one node
    if (temp->next == head) {
        free(temp);
        head = NULL;
        return;
    }

    // Traverse to second last
    while (temp->next->next != head) {
        temp = temp->next;
    }

    struct Node* last = temp->next;
    temp->next = head;
    free(last);
}

// Display circular list
void display() {
    if (head == NULL)
        return;

    struct Node* temp = head;

    do {
        printf("%d", temp->data);
        temp = temp->next;
        if (temp != head)
            printf(" ");
    } while (temp != head);
}

int main() {
    int n, x;
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        scanf("%d", &x);
        create(x);
    }

    deleteLast();
    display();

    return 0;
}
